use flake

# Build the `shh` CLI from the current source on every direnv reload and put it
# on PATH. `use flake` above provides the Go toolchain; the build uses the
# working-tree files, so each `direnv reload` (or file-triggered reload)
# reflects the latest code.
bindir="$(direnv_layout_dir)/bin"
mkdir -p "$bindir"
if go build -o "$bindir/shh" ./cmd/itsasecret; then
  PATH_add "$bindir"
  log_status "shh built -> $bindir/shh"
else
  log_error "shh build failed"
fi

# Rebuild when Go sources or module files change.
watch_dir cmd
watch_dir internal
watch_file go.mod go.sum
